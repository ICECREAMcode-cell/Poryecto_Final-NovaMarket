@model NovaMarket.Models.Venta

@{
    ViewData["Title"] = "Detalle Venta";
}

<h2>Detalle de Venta</h2>

<div class="card mb-3">

<div class="card-body">

<p><strong>ID:</strong> @Model.Id</p>

<p><strong>Fecha:</strong> @Model.Fecha</p>

<p><strong>Cliente:</strong> @Model.Cliente?.Nombre</p>

<p><strong>Empleado:</strong> @Model.Usuario?.Nombre</p>

<p><strong>Total:</strong> @Model.Total</p>

</div>

</div>

<h4>Productos</h4>

<table class="table table-striped">

<thead class="table-dark">

<tr>
<th>Producto</th>
<th>Cantidad</th>
<th>Precio Unitario</th>
<th>Subtotal</th>
</tr>

</thead>

<tbody>

@foreach(var item in Model.Detalles)
{

<tr>

<td>@item.Producto?.Nombre</td>

<td>@item.Cantidad</td>

<td>@item.PrecioUnitario</td>

<td>@item.Subtotal</td>

</tr>

}

</tbody>

</table>

<a asp-action="Index" class="btn btn-secondary">
Volver
</a>