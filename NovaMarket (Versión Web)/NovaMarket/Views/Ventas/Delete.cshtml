@model NovaMarket.Models.Venta

@{
    ViewData["Title"] = "Eliminar Venta";
}

<h2>Eliminar Venta</h2>

<div class="alert alert-danger">
    <h4>¿Estás seguro que deseas eliminar esta venta?</h4>
</div>

<div>
    <dl class="row">

        <dt class="col-sm-3">
            ID Venta
        </dt>
        <dd class="col-sm-9">
            @Model.Id
        </dd>

        <dt class="col-sm-3">
            Cliente
        </dt>
        <dd class="col-sm-9">
            @Model.Cliente?.Nombre
        </dd>

        <dt class="col-sm-3">
            Usuario
        </dt>
        <dd class="col-sm-9">
            @Model.Usuario?.Nombre
        </dd>

        <dt class="col-sm-3">
            Fecha
        </dt>
        <dd class="col-sm-9">
            @Model.Fecha
        </dd>

        <dt class="col-sm-3">
            Total
        </dt>
        <dd class="col-sm-9">
            Bs. @Model.Total
        </dd>

    </dl>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Eliminar
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancelar
    </a>
</form>